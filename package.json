{
  "name": "task02-persistent-storage-db-integration",
  "version": "1.0.0",
  "description": "REST API with persistent storage using MySQL and Sequelize ORM",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "seed": "npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sequelize": "^6.33.0",
    "mysql2": "^3.6.0",
    "dotenv": "^16.3.1",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.1"
  },
  "keywords": ["nodejs", "express", "mysql", "sequelize", "rest-api"],
  "author": "",
  "license": "ISC"
}
